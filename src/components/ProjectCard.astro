---
const { titulo, descripcion, imagen, enlace, tipo } = Astro.props;
const imagenUrl = typeof imagen === 'string' ? imagen : imagen?.src ?? '';
---

<a href={enlace} class="project-card">
    <div class="card-img" style={`background-image: url("${imagenUrl}");`}>
        <span class="project-type">{tipo}</span>
    </div>
    <div class="card-info">
        <h3>{titulo}</h3>
        <p>{descripcion}</p>
    </div>
</a>

<style>

.project-card {
    max-width: 30rem;
    background: var(--card-bg);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, border-color 0.3s ease;
    border: 1px solid #30363d;
}

.project-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: var(--accent);
}

.project-type{
    display: inline-block;
    background: var(--bg-color);
    padding: 5px 15px;
    margin: 5px;
    border-radius: 20px;
    border: 1px solid var(--accent);
    font-size: 0.75rem;
    position: absolute;
    top: 10px;
    left: 10px;
}

.card-img {
    height: 200px;
    background-size: cover;
    background-position: center;
    position: relative;
}

.card-info {
    padding: 1.5rem;
    color: var(--text-primary);
}
.card-info h3 {
    margin-bottom: 0.5rem;
    color: var(--accent);
}

@media (max-width: 768px) {
    .project-card {
        max-width: 100%;
    }
}
</style>